# Port configuration
PORT=3000

# Express Session secret key
SESSION_SECRET=runguaksara-secret-key-1234567890

# API Keys (Provide at least one of these for STT and Notulensi generation)
GEMINI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=

# Model Preferences
# Whisper STT model (Used if OPENROUTER_API_KEY is provided)
WHISPER_MODEL=openai/whisper-large-v3

# Gemini Live & Notulensi models
GEMINI_MODEL=gemini-2.5-flash
LLM_MODEL=google/gemini-2.5-flash

# Database Configuration (MySQL/MariaDB)
# If empty or connection fails, the system will fallback to JSON file-based database (db.json)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=runguaksara

# Default Admin Account Seed Credentials (Created on first run if database is empty)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=adminrunguaksara
